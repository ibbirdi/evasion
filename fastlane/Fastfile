require "json"
require "fileutils"

default_platform(:ios)

APPSTORE_SCREENSHOT_DISPLAY_ORDER = {
  "01_hero.jpg" => "01_hero.jpg",
  "02_library.jpg" => "02_library.jpg",
  "07_timer.jpg" => "03_timer.jpg",
  "05_spatial.jpg" => "04_spatial.jpg",
  "08_free_home.jpg" => "05_free_home.jpg",
  "03_detail_sheet.jpg" => "06_detail_sheet.jpg",
  "04_binaural.jpg" => "07_binaural.jpg",
  "06_presets.jpg" => "08_presets.jpg",
  "09_library_teaser.jpg" => "09_library_teaser.jpg",
  "10_paywall.jpg" => "10_paywall.jpg"
}.freeze

def oasis_repo_root
  candidates = [
    File.expand_path(__dir__),
    File.expand_path("..", __dir__),
    Dir.pwd,
    File.expand_path("..", Dir.pwd)
  ].uniq

  candidates.find do |candidate|
    File.exist?(File.join(candidate, "ios-native", "OasisNative.xcodeproj"))
  end || raise("Unable to locate repo root for OasisNative.xcodeproj")
end

def oasis_screenshot_ios_version
  explicit_version = ENV["SCREENSHOT_IOS_VERSION"].to_s.strip
  return explicit_version unless explicit_version.empty?

  runtimes = JSON.parse(`xcrun simctl list runtimes -j`).fetch("runtimes", [])
  ios_runtimes = runtimes.select do |runtime|
    runtime["isAvailable"] &&
      runtime["version"].to_s.length.positive? &&
      (runtime["platform"] == "iOS" || runtime["identifier"].to_s.include?("iOS"))
  end

  ios_runtimes.max_by { |runtime| Gem::Version.new(runtime["version"]) }&.fetch("version", nil)
rescue StandardError
  nil
end

def oasis_stage_appstore_media(repo_root)
  # `upload_to_app_store` expects one flat directory per locale containing
  # upload-ready media. Our composites live under
  # `fastlane/screenshots/<locale>/figma-pro/*.jpg` alongside raw captures,
  # so stage them into a dedicated folder to avoid shipping raw captures
  # or the `preview/` subdirectory.
  staging_root = File.join(repo_root, "fastlane", "appstore-upload")
  FileUtils.rm_rf(staging_root)
  FileUtils.mkdir_p(staging_root)

  composite_glob = File.join(repo_root, "fastlane", "screenshots", "*", "figma-pro", "*.jpg")
  staged_count = 0
  Dir.glob(composite_glob).each do |src|
    # src = .../fastlane/screenshots/<locale>/figma-pro/<slug>.jpg
    locale = File.basename(File.dirname(File.dirname(src)))
    next if locale == "preview" || locale == "test_output"
    dest_dir = File.join(staging_root, locale)
    FileUtils.mkdir_p(dest_dir)
    upload_name = APPSTORE_SCREENSHOT_DISPLAY_ORDER.fetch(File.basename(src), File.basename(src))
    FileUtils.cp(src, File.join(dest_dir, upload_name))
    staged_count += 1
  end
  UI.message("Staged #{staged_count} composite screenshots into #{staging_root}")

  UI.message("App Preview videos are intentionally not staged for App Store upload.")

  {
    staging_root: staging_root,
    screenshots: staged_count,
    app_previews: 0
  }
end

def oasis_assert_mac_appstore_media(repo_root)
  staging_root = File.join(repo_root, "fastlane", "appstore-upload-macos")
  locales = ["en-US", "fr-FR", "de-DE", "es-ES", "it", "pt-BR"]
  expected_per_locale = 5

  missing = locales.flat_map do |locale|
    locale_dir = File.join(staging_root, locale)
    screenshots = Dir.glob(File.join(locale_dir, "*.jpg"))
    screenshots.size == expected_per_locale ? [] : ["#{locale}: #{screenshots.size}/#{expected_per_locale} screenshots"]
  end

  UI.user_error!("Missing macOS App Store screenshots in #{staging_root}: #{missing.join(', ')}") unless missing.empty?

  {
    staging_root: staging_root,
    screenshots: locales.size * expected_per_locale
  }
end

platform :ios do
  desc "Generate App Store screenshots for the native iOS app with XCTest + snapshot"
  lane :screenshots do
    repo_root = oasis_repo_root
    ios_project = File.join(repo_root, "ios-native", "OasisNative.xcodeproj")
    output_directory = File.join(repo_root, "fastlane", "screenshots")
    buildlog_directory = File.join(repo_root, "fastlane", "buildlogs")
    derived_data_directory = File.join(repo_root, "fastlane", "snapshot-derived-data")
    screenshot_ios_version = oasis_screenshot_ios_version

    # Partial regeneration: when OASIS_SCREENSHOT_PARTIAL is set to any truthy
    # value, we skip clearing existing screenshots so prior slides are
    # preserved. Pair this with a hardcoded `onlyScenarios` filter inside the
    # UI test for a targeted rerun.
    only_filter_active = !ENV["OASIS_SCREENSHOT_PARTIAL"].to_s.strip.empty?

    capture_screenshots(
      project: ios_project,
      scheme: "OasisNative",
      # iPhone 17 Pro Max is the largest current App Store display class (6.9",
      # 1320 × 2868 @ 3x) so Figma comps get the highest-resolution source material.
      devices: [ENV["SCREENSHOT_DEVICE"] || "iPhone 17 Pro Max"],
      ios_version: screenshot_ios_version,
      languages: ENV["SCREENSHOT_LANGUAGES"]&.split(",")&.map(&:strip) || [
        "en-US",
        "fr-FR",
        "de-DE",
        "es-ES",
        "it",
        "pt-BR"
      ],
      output_directory: output_directory,
      clear_previous_screenshots: !only_filter_active,
      reinstall_app: true,
      erase_simulator: true,
      app_identifier: "com.jonathanluquet.drift",
      override_status_bar: true,
      localize_simulator: true,
      disable_slide_to_type: true,
      headless: false,
      concurrent_simulators: false,
      # `clean: true` forced a full rebuild on every language — with 6 languages,
      # that meant ~10 min of clean+compile wasted per run. The source didn't
      # change between languages, so reuse the compiled test bundle across them.
      clean: false,
      result_bundle: true,
      namespace_log_files: true,
      only_testing: ["OasisNativeUITests/OasisNativeScreenshots/testAppStoreScreenshots"],
      # Retries used to mask UI quiescence issues (animating backdrop + waveform).
      # Now that those views pause under screenshot automation we expect the first
      # run to succeed. Fail fast if it doesn't — a retry would silently double
      # the run time and hide regressions.
      number_of_retries: 0,
      launch_arguments: [
        "-OASISResetState YES",
        "-OASISImmersiveAudioEnabled YES"
      ],
      buildlog_path: buildlog_directory,
      derived_data_path: derived_data_directory
    )
  end

  desc "Alias for screenshot generation"
  lane :screenshots_only do
    screenshots
  end

  desc "Generate localized App Preview videos from the App Store composites"
  lane :app_previews do
    repo_root = oasis_repo_root
    sh("ruby", File.join(repo_root, "scripts", "generate_app_previews.rb"))
  end

  desc "Capture localized macOS menu bar panel screenshots"
  lane :mac_screenshots do
    repo_root = oasis_repo_root
    sh("ruby", File.join(repo_root, "scripts", "capture_macos_screenshots.rb"))
  end

  desc "Generate upload-ready macOS App Store screenshots from panel captures"
  lane :mac_appstore_assets do
    repo_root = oasis_repo_root
    sh("swift", File.join(repo_root, "scripts", "generate_mac_store_screenshot_comps.swift"))
  end

  desc "Capture and compose all localized macOS App Store screenshots"
  lane :mac_appstore_screenshots do
    mac_screenshots
    mac_appstore_assets
  end

  desc "Upload macOS screenshots + metadata to App Store Connect (no binary)"
  lane :mac_appstore_release do |options|
    repo_root = oasis_repo_root
    app_version = options[:app_version] || "1.0.0"
    staging_result = oasis_assert_mac_appstore_media(repo_root)

    upload_to_app_store(
      username: "jonathanluquet@me.com",
      app_identifier: "com.jonathanluquet.drift",
      app_version: app_version,
      platform: "osx",
      metadata_path: File.join(repo_root, "fastlane", "metadata"),
      screenshots_path: staging_result[:staging_root],
      skip_binary_upload: true,
      skip_metadata: false,
      skip_screenshots: false,
      skip_app_version_update: false,
      overwrite_screenshots: true,
      submit_for_review: false,
      force: true,
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: false,
      version_check_wait_retry_limit: 15
    )
  end

  desc "Stage upload-ready screenshots without uploading App Preview videos"
  lane :stage_appstore_assets do
    repo_root = oasis_repo_root
    oasis_stage_appstore_media(repo_root)
  end

  desc "Upload metadata to App Store Connect without screenshots"
  lane :appstore_metadata do |options|
    repo_root = oasis_repo_root
    app_version = options[:app_version] || "1.5.0"

    upload_to_app_store(
      username: "jonathanluquet@me.com",
      app_identifier: "com.jonathanluquet.drift",
      app_version: app_version,
      metadata_path: File.join(repo_root, "fastlane", "metadata"),
      skip_binary_upload: true,
      skip_metadata: false,
      skip_screenshots: true,
      skip_app_version_update: false,
      submit_for_review: false,
      force: true,
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: false,
      version_check_wait_retry_limit: 15
    )
  end

  desc "Archive + export an App Store IPA and upload it to TestFlight/App Store Connect"
  lane :build_and_upload do |options|
    repo_root = oasis_repo_root
    ios_project = File.join(repo_root, "ios-native", "OasisNative.xcodeproj")
    output_directory = File.join(repo_root, "fastlane", "builds")
    buildlog_directory = File.join(repo_root, "fastlane", "buildlogs")
    ipa_name = options[:ipa_name] || "OasisNative.ipa"

    build_app(
      project: ios_project,
      scheme: "OasisNative",
      configuration: "Release",
      export_method: "app-store",
      clean: true,
      output_directory: output_directory,
      output_name: ipa_name,
      buildlog_path: buildlog_directory,
      include_bitcode: false,
      include_symbols: true
    )

    upload_to_testflight(
      username: "jonathanluquet@me.com",
      app_identifier: "com.jonathanluquet.drift",
      ipa: File.join(output_directory, ipa_name),
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )
  end

  desc "Upload screenshots + metadata to App Store Connect (no binary)"
  lane :appstore_release do |options|
    repo_root = oasis_repo_root
    app_version = options[:app_version] || "1.5.0"
    staging_result = oasis_stage_appstore_media(repo_root)

    upload_to_app_store(
      username: "jonathanluquet@me.com",
      app_identifier: "com.jonathanluquet.drift",
      app_version: app_version,
      metadata_path: File.join(repo_root, "fastlane", "metadata"),
      screenshots_path: staging_result[:staging_root],
      skip_binary_upload: true,
      skip_metadata: false,
      skip_screenshots: false,
      skip_app_version_update: false,
      overwrite_screenshots: true,
      submit_for_review: false,
      force: true,
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: false,
      version_check_wait_retry_limit: 15
    )
  end
end
