scheme("OasisNative")

devices([
  ENV["SCREENSHOT_DEVICE"] || "iPhone 17 Pro Max"
])

screenshot_ios_version = oasis_screenshot_ios_version
ios_version(screenshot_ios_version) if screenshot_ios_version

