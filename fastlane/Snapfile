output_directory(File.join(repo_root, "fastlane", "screenshots"))
reinstall_app(true)
erase_simulator(true)
app_identifier("com.jonathanluquet.drift")
override_status_bar(true)
localize_simulator(true)
disable_slide_to_type(true)
headless(false)
concurrent_simulators(false)
clean(true)
result_bundle(true)
namespace_log_files(true)
number_of_retries(0)
launch_arguments([
  "-OASISResetState YES"
])
