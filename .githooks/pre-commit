#!/usr/bin/env bash
# .githooks/pre-commit
#
# Non-blocking warning when source files are staged without an AI-memory update.
#
# Activate (one-time, per clone):
#   git config core.hooksPath .githooks
#
# Bypass (when justified — please update memory in the next commit):
#   git commit --no-verify

set -euo pipefail

repo_root=$(git rev-parse --show-toplevel)
script="$repo_root/scripts/ai-memory/memory-touched.sh"

if [[ ! -x "$script" ]]; then
  exit 0
fi

if "$script" staged; then
  exit 0
fi

# memory-touched.sh exited 1 — print a final note and let the commit proceed.
echo
echo "(Warning only, commit will proceed. To bypass on the next commit: git commit --no-verify)"
exit 0
