    "onboarding.page1.subtitle": {
      "comment": "Onboarding page 1 subtitle.",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mische Naturklänge, passe jede Lautstärke an und platziere sie in 3D-Audio um dich herum."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Mix nature sounds, adjust each volume, and place them around you in 3D audio."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mezcla sonidos de la naturaleza, ajusta cada volumen y colócalos a tu alrededor en audio 3D."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mixez des sons de la nature, ajustez chaque volume et placez-les autour de vous en audio 3D."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Mixa suoni della natura, regola ogni volume e posizionali intorno a te in audio 3D."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Mixe sons da natureza, ajuste cada volume e posicione tudo ao seu redor em áudio 3D."
          }
        }
      }
    },
    "onboarding.page1.title": {
