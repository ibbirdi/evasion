    "onboarding.page2.subtitle": {
      "comment": "Onboarding page 2 subtitle.",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Starte einen Schlaf-Timer, sperre dein Handy und lass Oasis im Hintergrund laufen. Alles funktioniert offline."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Start a sleep timer, lock your phone, and let Oasis play in the background. Everything works offline."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Activa un temporizador, bloquea tu iPhone y deja que Oasis suene en segundo plano. Todo funciona sin conexión."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lancez un minuteur, verrouillez l'iPhone et laissez Oasis jouer en arrière-plan. Tout fonctionne hors ligne."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Avvia un timer, blocca il telefono e lascia Oasis in background. Tutto funziona offline."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Inicie um timer, bloqueie o celular e deixe o Oasis tocar em segundo plano. Tudo funciona offline."
          }
        }
      }
    },
    "onboarding.page2.title": {
      "comment": "Onboarding page 2 title.",
      "localizations": {
        "de": {
