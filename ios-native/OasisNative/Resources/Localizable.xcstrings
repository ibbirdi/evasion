    "onboarding.page3.subtitle": {
      "comment": "Onboarding page 3 subtitle.",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Starte kostenlos mit 3 Sounds und 3D-Audio. Schalte 17 weitere Sounds, längere Timer und Binauralmodi frei — kein Abo, nie."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Start free with 3 sounds and 3D audio. Unlock 17 more sounds, longer timers and binaural modes — no subscription, ever."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Empieza gratis con 3 sonidos y audio 3D. Desbloquea 17 sonidos más, temporizadores largos y modos binaurales — sin suscripción."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Commencez gratuitement avec 3 sons et l'audio 3D. Débloquez 17 sons, des minuteurs plus longs et les modes binauraux — sans abonnement."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Inizia gratis con 3 suoni e audio 3D. Sblocca 17 suoni, timer più lunghi e modalità binaurali — senza abbonamento, mai."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Comece grátis com 3 sons e áudio 3D. Desbloqueie 17 sons, timers mais longos e modos binaurais — sem assinatura, nunca."
          }
        }
      }
    },
