    "onboarding.page1.title": {
      "comment": "Onboarding page 1 title.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Your sound bed for sleep" } },
        "fr": { "stringUnit": { "state": "translated", "value": "Votre fond sonore pour dormir" } },
        "de": { "stringUnit": { "state": "translated", "value": "Dein Klangteppich zum Einschlafen" } },
        "es": { "stringUnit": { "state": "translated", "value": "Tu fondo sonoro para dormir" } },
        "it": { "stringUnit": { "state": "translated", "value": "Il tuo sottofondo per dormire" } },
        "pt": { "stringUnit": { "state": "translated", "value": "Seu som de fundo para dormir" } }
      }
    },
    "onboarding.page1.subtitle": {
      "comment": "Onboarding page 1 subtitle.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Mix nature sounds, adjust each volume, and place them around you in 3D audio." } },
        "fr": { "stringUnit": { "state": "translated", "value": "Mixez des sons de la nature, ajustez chaque volume et placez-les autour de vous en audio 3D." } },
        "de": { "stringUnit": { "state": "translated", "value": "Mische Naturklänge, passe jede Lautstärke an und platziere sie in 3D-Audio um dich herum." } },
        "es": { "stringUnit": { "state": "translated", "value": "Mezcla sonidos de la naturaleza, ajusta cada volumen y colócalos a tu alrededor en audio 3D." } },
        "it": { "stringUnit": { "state": "translated", "value": "Mixa suoni della natura, regola ogni volume e posizionali intorno a te in audio 3D." } },
        "pt": { "stringUnit": { "state": "translated", "value": "Mixe sons da natureza, ajuste cada volume e posicione tudo ao seu redor em áudio 3D." } }
      }
    },
    "onboarding.page2.title": {
      "comment": "Onboarding page 2 title.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Set a timer, drift off" } },
        "fr": { "stringUnit": { "state": "translated", "value": "Lancez un minuteur, endormez-vous" } },
        "de": { "stringUnit": { "state": "translated", "value": "Timer starten, einschlafen" } },
        "es": { "stringUnit": { "state": "translated", "value": "Pon un temporizador, descansa" } },
        "it": { "stringUnit": { "state": "translated", "value": "Avvia un timer, addormentati" } },
        "pt": { "stringUnit": { "state": "translated", "value": "Ative um timer, relaxe" } }
      }
    },
    "onboarding.page2.subtitle": {
      "comment": "Onboarding page 2 subtitle.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Start a sleep timer, lock your phone, and let Oasis play in the background. Everything works offline." } },
        "fr": { "stringUnit": { "state": "translated", "value": "Lancez un minuteur, verrouillez l'iPhone et laissez Oasis jouer en arrière-plan. Tout fonctionne hors ligne." } },
        "de": { "stringUnit": { "state": "translated", "value": "Starte einen Schlaf-Timer, sperre dein Handy und lass Oasis im Hintergrund laufen. Alles funktioniert offline." } },
        "es": { "stringUnit": { "state": "translated", "value": "Activa un temporizador, bloquea tu iPhone y deja que Oasis suene en segundo plano. Todo funciona sin conexión." } },
        "it": { "stringUnit": { "state": "translated", "value": "Avvia un timer, blocca il telefono e lascia Oasis in background. Tutto funziona offline." } },
        "pt": { "stringUnit": { "state": "translated", "value": "Inicie um timer, bloqueie o celular e deixe o Oasis tocar em segundo plano. Tudo funciona offline." } }
      }
    },
    "onboarding.page3.title": {
      "comment": "Onboarding page 3 title.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "14 sounds, one purchase" } },
        "fr": { "stringUnit": { "state": "translated", "value": "14 sons, un seul achat" } },
        "de": { "stringUnit": { "state": "translated", "value": "14 Sounds, ein Kauf" } },
        "es": { "stringUnit": { "state": "translated", "value": "14 sonidos, una sola compra" } },
        "it": { "stringUnit": { "state": "translated", "value": "14 suoni, un solo acquisto" } },
        "pt": { "stringUnit": { "state": "translated", "value": "14 sons, uma única compra" } }
      }
    },
    "onboarding.page3.subtitle": {
      "comment": "Onboarding page 3 subtitle.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Start free with 3 sounds and 3D audio. Unlock 11 more sounds, longer timers and binaural modes — no subscription, ever." } },
        "fr": { "stringUnit": { "state": "translated", "value": "Commencez gratuitement avec 3 sons et l'audio 3D. Débloquez 11 sons, des minuteurs plus longs et les modes binauraux — sans abonnement." } },
