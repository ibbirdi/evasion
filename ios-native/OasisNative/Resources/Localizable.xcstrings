    "paywall.subtitle.generic": {
      "comment": "Generic paywall subtitle summarizing the full premium offer.",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schalte 11 weitere Sounds, Timer für 1/2 Std. und unbegrenzt gespeicherte Mixe frei. Ein Kauf, kein Abo."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Unlock 11 more sounds, 1 hr/2 hr timers and unlimited saved mixes. One purchase, no subscription."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desbloquea 11 sonidos más, temporizadores de 1/2 h y mezclas guardadas ilimitadas. Una compra, sin suscripción."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Débloquez 11 sons en plus, les minuteurs 1 h/2 h et les mix illimités. Un seul achat, sans abonnement."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sblocca 11 suoni in più, timer da 1/2 h e mix salvati illimitati. Un solo acquisto, nessun abbonamento."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Desbloqueie 11 sons extras, timers de 1/2 h e mixes salvos ilimitados. Uma compra, sem assinatura."
          }
        }
      }
    },
