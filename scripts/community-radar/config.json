{
  "app": {
    "name": "Oasis",
    "appStoreBaseUrl": "https://apps.apple.com/app/apple-store/id6759493932",
    "campaignProviderToken": "",
    "defaultLocale": "en-US"
  },
  "run": {
    "daysBack": 21,
    "minScore": 55,
    "maxItems": 15,
    "delayMs": 1100,
    "redditMaxQueries": 20,
    "hnMaxQueries": 10
  },
  "guardrails": {
    "dailyReplyCap": 5,
    "dailyLinkCap": 1,
    "alwaysDiscloseDeveloperConnection": true,
    "neverAutoPost": true,
    "neverSendUnsolicitedDMs": true
  },
  "reddit": {
    "enabled": true,
    "userAgent": "OasisCommunityRadar/0.1 by jonathanluquet",
    "queries": [
      {
        "id": "reddit_sleep_nosub",
        "enabled": true,
        "segment": "subscription",
        "campaign": "reddit_sleep_nosub",
        "terms": "\"sleep app\" \"no subscription\" OR \"white noise app\" \"no subscription\"",
        "subreddits": ["sleep", "iosapps", "iOS"],
        "intent": "Find people actively avoiding subscriptions in sleep or white-noise apps."
      },
      {
        "id": "reddit_ios_sleep_app_reco",
        "enabled": true,
        "segment": "sleep",
        "campaign": "reddit_ios_sleep_reco",
        "terms": "\"sleep app\" OR \"rain sounds\" OR \"white noise app\" OR \"brown noise app\"",
        "subreddits": ["iosapps", "iOS", "iphone"],
        "intent": "Find iPhone owners asking for sleep, rain, white-noise, or brown-noise app recommendations."
      },
      {
        "id": "reddit_bettersleep_alt",
        "enabled": true,
        "segment": "subscription",
        "campaign": "reddit_bettersleep_alt",
        "terms": "\"BetterSleep\" \"subscription\" OR \"BetterSleep\" \"paywall\" OR \"Calm\" \"subscription\"",
        "subreddits": ["sleep", "insomnia", "iosapps"],
        "intent": "Find people complaining about subscription-heavy sleep apps."
      },
      {
        "id": "reddit_calm_headspace_alt",
        "enabled": true,
        "segment": "subscription",
        "campaign": "reddit_calm_alt",
        "terms": "\"Calm\" \"subscription\" OR \"Headspace\" \"subscription\" OR \"meditation app\" \"no subscription\"",
        "subreddits": ["iosapps", "meditation", "productivity"],
        "intent": "Find users replacing subscription-heavy wellness apps with simpler one-time-purchase tools."
      },
      {
        "id": "reddit_white_noise_reco",
        "enabled": true,
        "segment": "sleep",
        "campaign": "reddit_sleep_reco",
        "terms": "\"white noise app\" OR \"rain sounds app\" OR \"sleep sound app\"",
        "subreddits": ["sleep", "insomnia", "iosapps"],
        "intent": "Find recommendation threads for sleep sounds, white noise, rain, or brown noise."
      },
      {
        "id": "reddit_insomnia_noise_masking",
        "enabled": true,
        "segment": "sleep",
        "campaign": "reddit_insomnia_noise",
        "terms": "\"rain sounds\" OR \"white noise\" OR \"brown noise\" OR \"sleep timer\"",
        "subreddits": ["sleep", "insomnia"],
        "intent": "Find sleep-sound threads where Oasis can be suggested without making medical claims."
      },
      {
        "id": "reddit_focus_ambient",
        "enabled": true,
        "segment": "focus",
        "campaign": "reddit_focus_ambient",
        "terms": "\"focus app\" \"background noise\" OR \"ambient sounds\" \"studying\"",
        "subreddits": ["productivity", "GetStudying", "iosapps"],
        "intent": "Find people using ambience for deep work, reading, study, or focus."
      },
      {
        "id": "reddit_deepwork_noise",
        "enabled": true,
        "segment": "focus",
        "campaign": "reddit_deepwork_noise",
        "terms": "\"background noise\" \"focus\" OR \"ambient sounds\" \"deep work\" OR \"rain sounds\" \"study\"",
        "subreddits": ["productivity", "GetStudying", "deepwork"],
        "intent": "Find focus and study threads where stable, non-music ambience is the user need."
      },
      {
        "id": "reddit_travel_offline",
        "enabled": true,
        "segment": "travel",
        "campaign": "reddit_travel_offline",
        "terms": "\"offline\" \"sleep app\" OR \"hotel noise\" \"sleep\" OR \"travel\" \"white noise\"",
        "subreddits": ["travel", "onebag", "sleep", "iosapps"],
        "intent": "Find travelers who need offline background sound for hotels, flights, or noisy rooms."
      },
      {
        "id": "reddit_hotel_noise",
        "enabled": true,
        "segment": "travel",
        "campaign": "reddit_hotel_noise",
        "terms": "\"hotel noise\" \"sleep\" OR \"noisy hotel\" OR \"sleep on plane\" OR \"white noise\" \"travel\"",
        "subreddits": ["travel", "onebag", "solotravel", "sleep"],
        "intent": "Find high-intent travel sleep problems where offline audio is a concrete advantage."
      },
      {
        "id": "reddit_indie_feedback",
        "enabled": false,
        "segment": "maker",
        "campaign": "reddit_indie_feedback",
        "terms": "\"iOS app\" \"no subscription\" OR \"App Store\" \"one time purchase\"",
        "subreddits": ["SideProject", "ShowMeYourApps", "iosdev", "indiehackers"],
        "intent": "Find founder-friendly threads where a transparent maker story can get feedback."
      }
    ]
  },
  "hackerNews": {
    "enabled": true,
    "queries": [
      {
        "id": "hn_no_subscription_apps",
        "enabled": true,
        "segment": "maker",
        "campaign": "hn_maker_no_subscription",
        "terms": "\"no subscription\" \"iOS app\""
      },
      {
        "id": "hn_ask_apps_no_subscription",
        "enabled": true,
        "segment": "maker",
        "campaign": "hn_ask_no_subscription",
        "terms": "\"Ask HN\" \"no subscription\" \"app\""
      },
      {
        "id": "hn_offline_audio_app",
        "enabled": true,
        "segment": "maker",
        "campaign": "hn_maker_offline_audio",
        "terms": "\"offline\" \"audio\" \"iOS\""
      },
      {
        "id": "hn_background_noise",
        "enabled": true,
        "segment": "focus",
        "campaign": "hn_background_noise",
        "terms": "\"background noise\" \"focus\""
      },
      {
        "id": "hn_sleep_app",
        "enabled": true,
        "segment": "maker",
        "campaign": "hn_maker_sleep_app",
        "terms": "\"sleep app\""
      }
    ]
  },
  "manual": {
    "enabled": false,
    "file": "scripts/community-radar/manual-items.example.json"
  }
}
